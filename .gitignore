# Raw Assets (Sovereign Lockdown): unencrypted source assets stay local.
native_client/assets/
assets_sovereign_backup/
research_files/

# Keep the encrypted vault in the tree.
!native_client/assets.vault

# Local databases
*.db
*.db-shm
*.db-wal

# Dev tooling (vault packer is local-only, ignored from source)
native_client/vault_lock.go

# System
.DS_Store

