# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

/node_modules
/yarn-error.log

.byebug_history

# Ignore application configuration
/config/application.yml

# Go build artifacts
/skype
/skype-nexus
/skype.exe
/skype-nexus.exe
/dist/
*.db
*.db-journal

# Large archives and research blobs
oluo3y.7z
research_files/*.exe
research_files/Offline Session/
*.7z

# IDE
.vscode/
.idea/
*.code-workspace

# Agent runtime
.claude/

# Research materials (too large for git, keep locally)
research_files/
native_client/assets/original_resources/

# Built binaries (never commit)
nexus_server/nexus-server
nexus_server/skype-nexus
native_client/native_client
native_client/skype
