# Phaze Sovereign Git Ignore
# Protects raw assets and build artifacts from the tree.

# Local Make overrides (paths, secrets for dev machines)
local.mk

# Build artifacts
bin/
fyne-cross/
*.exe
*.apk
*.7z
*.log
.fuse_hidden*

# Client binaries (repo-root + per-module)
/tazher-client
/tazher-nexus
/tazher-nexus-linux
/tazher-native-linux
/skype-nexus
/skype_test
/phaze
/phaze-nexus
native_client/native_client
native_client/Phaze.exe
native_client/Phaze.apk
native_client/Phaze.linux
native_client/*.keystore
native_client/*.jks
nexus_server/public/downloads/Phaze.apk
nexus_server/public/downloads/Phaze.exe
nexus_server/public/downloads/Phaze.linux
native_client/phaze
native_client/tazher-native
native_client/private-skype
native_client/shadow_test
native_client/skype_test
native_client/velocity_test
native_client/skype-classic
native_client/SkypeSetup_*.exe
native_client/scratch/SkypeSetup_*.exe
nexus_server/phaze-nexus
nexus_server/nexus-server
nexus_server/skype-nexus
nexus_server/tazher-nexus

# Raw Assets (Sovereign Lockdown): unencrypted source assets stay local.
native_client/assets/
assets_sovereign_backup/
research_files/

# Keep the encrypted vault in the tree.
!native_client/assets.vault

# Local databases
*.db
*.db-shm
*.db-wal

# Dev tooling (vault packer is local-only, ignored from source)
native_client/vault_lock.go

# System
.DS_Store

# Legacy reverse-engineering trees (Skype dumps, Ghidra exports) are intentionally
# not part of this repo — add them only in a private fork if you still need them.
