# TAZHER Nexus Infrastructure Configuration

# Database
DATABASE_URL=nexus.db

# Sovereign Media (CoTURN)
# The master secret shared with /etc/turnserver.conf
TAZHER_TURN_SECRET=TAZHER_ALPHA_GHOST_741_MINT

# The public address of your TURN server
# If testing locally, use turn:127.0.0.1:3478
# In production, use your VPS IP or Domain
TAZHER_TURN_URL=turn:127.0.0.1:3478

# Signaling
BIND_ADDR=0.0.0.0
PORT=8080

# Telephony (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
