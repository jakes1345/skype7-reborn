# TAZHER Nexus Infrastructure Configuration

# Database
DATABASE_URL=nexus.db

# Sovereign Media (CoTURN)
# Must match static-auth-secret in scripts/phaze_turnserver.conf
PHAZE_TURN_SECRET=CHANGE_ME_openssl_rand_hex_32

# The public address of your TURN server
# If testing locally, use turn:127.0.0.1:3478
# In production, use your VPS IP or Domain
PHAZE_TURN_URL=turn:127.0.0.1:3478

# Set to "true" for 10-minute short-term creds; otherwise 24h.
PHAZE_TURN_SHORT_TERM=false

# Signaling
BIND_ADDR=0.0.0.0
PORT=8080

# Telephony (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
